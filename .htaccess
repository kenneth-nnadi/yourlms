Options -Indexes +FollowSymLinks

# Send all web traffic into public/ — URLs stay /yourlms/login.php (not /yourlms/public/...)
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteRule ^public/ - [L]
  RewriteRule ^(config\.php|config\.local\.php|composer\.(json|lock)|\.env|\.git) - [F,L]
  RewriteRule ^(includes|database|data|deploy|tests|docs|scripts|vendor)(/|$) - [F,L]
  RewriteRule ^(.*)$ public/$1 [L]
</IfModule>