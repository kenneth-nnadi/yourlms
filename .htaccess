Options -Indexes +FollowSymLinks

# Apache/CGI often strips Authorization before PHP — required for API Bearer tokens.
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteCond %{HTTP:Authorization} .
  RewriteRule ^ - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]
</IfModule>
<IfModule mod_setenvif.c>
  SetEnvIf Authorization "(.*)" HTTP_AUTHORIZATION=$1
</IfModule>

# Block direct web access to local config (Apache 2.4+)
<IfModule mod_authz_core.c>
  <FilesMatch "^(config\.local\.php|config\.php|\.install-lock)$">
    Require all denied
  </FilesMatch>
</IfModule>

# Apache 2.2 fallback
<IfModule !mod_authz_core.c>
  <FilesMatch "^(config\.local\.php|config\.php|\.install-lock)$">
    Order allow,deny
    Deny from all
  </FilesMatch>
</IfModule>